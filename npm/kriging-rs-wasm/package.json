{
  "name": "kriging-rs-wasm",
  "version": "0.1.0",
  "description": "TypeScript-first WebAssembly bindings for kriging-rs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-murphy/kriging-rs.git",
    "directory": "npm/kriging-rs-wasm"
  },
  "homepage": "https://github.com/m-murphy/kriging-rs#readme",
  "bugs": {
    "url": "https://github.com/m-murphy/kriging-rs/issues"
  },
  "author": "Maxwell Murphy <mm@maxmurphy.dev>",
  "keywords": [
    "kriging",
    "geostatistics",
    "wasm",
    "interpolation",
    "spatial"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": true,
  "files": [
    "dist",
    "pkg",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "clean": "rm -rf dist pkg",
    "build:wasm": "wasm-pack build ../.. --release --target web --out-dir npm/kriging-rs-wasm/pkg -- --features wasm",
    "build:wasm:gpu": "wasm-pack build ../.. --release --target web --out-dir npm/kriging-rs-wasm/pkg -- --features wasm,gpu",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:wasm && npm run build:ts",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.js\"",
    "verify": "npm run typecheck:contracts && npm run lint && npm run build && npm run smoke && npm test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.0"
  }
}
