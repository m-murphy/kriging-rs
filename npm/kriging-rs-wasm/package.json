{
  "name": "kriging-rs-wasm",
  "version": "0.1.0",
  "description": "TypeScript-first WebAssembly bindings for kriging-rs",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "pkg",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "clean": "rm -rf dist pkg",
    "build:wasm": "wasm-pack build ../.. --release --no-opt --target web --out-dir npm/kriging-rs-wasm/pkg -- --features wasm",
    "build:wasm:gpu": "wasm-pack build ../.. --release --no-opt --target web --out-dir npm/kriging-rs-wasm/pkg -- --features wasm,gpu",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:wasm && npm run build:ts",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "verify": "npm run typecheck:contracts && npm run build && npm run smoke"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
